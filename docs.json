{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "venus",
  "appearance": "dark",
  "name": "OpenSeller",
  "colors": {
    "primary": "#5B66FF",
    "light": "#8B96FF",
    "dark": "#3245FF",
    "background": {
      "dark": "#060A1A",
      "light": "#FFFFFF"
    }
  },
  "favicon": "/favicon.svg",
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Getting Started",
            "pages": [
              "index",
              "getting-started/quick-start",
              "getting-started/onboarding"
            ]
          },
          {
            "group": "Core Features",
            "pages": [
              "features/chat-agent",
              "features/connections"
            ]
          },
          {
            "group": "Analytics",
            "pages": [
              "analytics/profit-tracker"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Website",
          "href": "https://openseller.io",
          "icon": "globe"
        }
      ]
    }
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "mailto:hello@openseller.io"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Get Started",
      "href": "https://openseller.io"
    }
  },
  "footer": {
    "socials": {
      "x": "https://x.com/openseller",
      "website": "https://openseller.io"
    }
  },
  "rounded": "default"
}
